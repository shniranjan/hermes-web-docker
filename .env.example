# ── Required: at least one API key ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-***
OPENAI_API_KEY=sk-***
DEEPSEEK_API_KEY=sk-***

# ── Production HTTPS (Let's Encrypt) ─────────────────────────────────────
# Required for the production stack (docker-compose.yml).
# Your DNS must point to this server before first run.
DOMAIN=hermes.yourdomain.com

# Shared secret for dashboard access protection.
# Any long random string. The browser sends this as X-Access-Key header.
# Generate one: openssl rand -hex 32
ACCESS_KEY_SECRET=change-me-to-a-random-string

# ── Optional ─────────────────────────────────────────────────────────────
# UID/GID to run Hermes as inside the container (default: 1000)
# HERMES_UID=1000
# HERMES_GID=1000

# Set to 0 to disable INSECURE mode (if you want Hermes to enforce its own HTTPS)
# HERMES_DASHBOARD_INSECURE=1
