# ── Required: at least one API key ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-***
OPENAI_API_KEY=sk-***
DEEPSEEK_API_KEY=sk-***

# ── Required: dashboard password ────────────────────────────────────────
# The password for accessing the Hermes web dashboard.
# All stacks require this (local, self-signed, and production).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me-to-a-secure-password

# ── Production HTTPS (Let's Encrypt) ─────────────────────────────────────
# Required for the production stack (docker-compose.yml + nginx).
# Your DNS must point to this server before first run.
DOMAIN=hermes.yourdomain.com

# Shared secret for dashboard access protection (alternative to password).
# Any long random string. The browser sends this as X-Access-Key header.
# Generate one: openssl rand -hex 32
# Leave empty if using password auth only.
ACCESS_KEY_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────
# UID/GID to run Hermes as inside the container (default: 1000)
# HERMES_UID=1000
# HERMES_GID=1000

# Set to 1 to disable HTTPS/auth enforcement (NOT recommended for anything
# but isolated, fully-trusted dev environments)
# HERMES_DASHBOARD_INSECURE=1
